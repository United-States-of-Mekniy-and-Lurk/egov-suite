FROM node:24-alpine AS web-assets
WORKDIR /web

COPY sal/src/CitizenService.Web/package.json sal/src/CitizenService.Web/package-lock.json ./
COPY sal/src/CitizenService.Web/scripts/ scripts/
RUN npm ci

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY sal/CitizenService.slnx ./
COPY sal/src/CitizenService.Web/CitizenService.Web.csproj src/CitizenService.Web/
COPY platform/src/Egov.Platform.Forms/Egov.Platform.Forms.csproj ../platform/src/Egov.Platform.Forms/
COPY platform/src/Egov.Platform.Identity/Egov.Platform.Identity.csproj ../platform/src/Egov.Platform.Identity/

RUN dotnet restore src/CitizenService.Web/CitizenService.Web.csproj

COPY sal/ .
COPY platform/ ../platform/
COPY --from=web-assets /web/wwwroot/lib/formio/ src/CitizenService.Web/wwwroot/lib/formio/
RUN dotnet publish src/CitizenService.Web/CitizenService.Web.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

COPY --from=build /app/publish .
COPY translations/ /app/translations/

USER 1001:1001
ENV ASPNETCORE_URLS=http://+:8080
ENV Translations__Path=/app/translations
EXPOSE 8080

ENTRYPOINT ["dotnet", "CitizenService.Web.dll"]
