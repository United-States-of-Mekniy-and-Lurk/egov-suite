@page
@model CitizenService.Web.Pages.Admin.FormsModel
@using System.Text.Json
@{
    ViewData["Title"] = L["admin.forms.title"].Value;
}

<header class="mklu-admin-page-header">
    <p class="mklu-eyebrow">@L["nav.admin"]</p>
    <h1 class="mklu-heading-1">@L["admin.forms.title"]</h1>
    <p class="mklu-text-secondary">@L["admin.forms.description"]</p>
</header>

<div class="mklu-admin-workspace">
    <partial name="_AdminSidebar" model='new CitizenService.Web.Models.AdminSidebarViewModel { ActiveSection = "forms", Fields = Model.Definitions }' />

    <div class="mklu-admin-content">
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="mklu-alert @(Model.IsError ? "mklu-alert-error" : "mklu-alert-success")" role="status">
                @Model.Message
            </div>
        }

        <section class="mklu-admin-section">
            <div class="mklu-section-heading">
                <div>
                    <h2 class="mklu-heading-2">@L["admin.forms.builder"]</h2>
                    <p class="mklu-text-secondary">@L["admin.forms.builder_help"]</p>
                </div>
                @if (Model.Forms.Any(form => form.IsActive && form.Name == Model.FormName))
                {
                    var activeVersion = Model.Forms.First(form => form.IsActive && form.Name == Model.FormName);
                    <span class="mklu-version-badge">v@activeVersion.Version @L["common.active"].Value.ToLowerInvariant()</span>
                }
            </div>

            <form method="post" class="mklu-admin-form" id="form-builder-form">
                <div class="mklu-form-grid">
                    <div class="mklu-field">
                        <label asp-for="FormName">@L["admin.forms.name"]</label>
                        <input asp-for="FormName" required />
                    </div>
                    <div class="mklu-field">
                        <label asp-for="TitleEn">@L["admin.forms.title_en"]</label>
                        <input asp-for="TitleEn" required />
                    </div>
                    <div class="mklu-field">
                        <label asp-for="TitleCs">@L["admin.forms.title_cs"]</label>
                        <input asp-for="TitleCs" />
                    </div>
                </div>

                <textarea asp-for="FormDefinitionJson" hidden></textarea>
                <div id="formio-builder" class="mklu-form-builder" aria-label="@L["admin.forms.builder"]"></div>

                <div class="mklu-form-actions">
                    <button type="submit" class="mklu-btn mklu-btn-filled" id="publish-form" disabled>@L["admin.forms.publish"]</button>
                    <span class="mklu-text-secondary">@L["admin.forms.publish_help"]</span>
                </div>
            </form>
        </section>

        <section class="mklu-admin-section">
            <h2 class="mklu-heading-2">@L["admin.forms.versions"]</h2>
            @if (Model.Forms.Count == 0)
            {
                <p class="mklu-text-secondary">@L["admin.forms.no_versions"]</p>
            }
            else
            {
                <div class="mklu-table-wrap">
                    <table class="table mklu-admin-table">
                        <thead>
                            <tr>
                                <th>@L["admin.forms.name"]</th>
                                <th>@L["admin.forms.version"]</th>
                                <th>@L["common.status"]</th>
                                <th>@L["common.created"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var form in Model.Forms)
                            {
                                <tr>
                                    <td><code>@form.Name</code></td>
                                    <td>v@form.Version</td>
                                    <td>@(form.IsActive ? L["common.active"] : L["common.inactive"])</td>
                                    <td>@form.CreatedAt.ToString("d")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/lib/formio/formio.full.min.js"></script>
    <script>
        (() => {
            const formElement = document.getElementById('form-builder-form');
            const definitionElement = document.getElementById('FormDefinitionJson');
            const registryFields = @Html.Raw(JsonSerializer.Serialize(
                Model.Definitions.Where(field => field.IsActive).OrderBy(field => field.SortOrder),
                new JsonSerializerOptions(JsonSerializerDefaults.Web)));

            const typeMap = {
                MultilineText: 'textarea',
                Date: 'datetime',
                Integer: 'number',
                Decimal: 'number',
                Boolean: 'checkbox',
                Select: 'select'
            };
            const registryComponents = {};

            for (const field of registryFields) {
                if (field.fieldType === 'Select' && field.optionSourceType !== 'Static') continue;

                const schema = {
                    label: field.labels.en ?? field.key,
                    key: field.key,
                    type: typeMap[field.fieldType] ?? 'textfield',
                    input: true,
                    validate: { required: field.isRequired },
                    properties: {
                        persistence: 'registry',
                        labels: JSON.stringify(field.labels)
                    }
                };
                if (field.fieldType === 'Date') schema.enableTime = false;
                if (field.fieldType === 'Integer') schema.validate.integer = true;
                if (field.fieldType === 'Select') {
                    schema.data = {
                        values: (field.staticOptions ?? []).map(option => ({
                            label: option.labels.en ?? option.value,
                            value: option.value
                        }))
                    };
                    schema.properties.optionLabels = JSON.stringify(
                        Object.fromEntries((field.staticOptions ?? []).map(option => [option.value, option.labels])));
                }

                registryComponents[field.key] = {
                    title: field.labels.en ?? field.key,
                    key: field.key,
                    icon: 'database',
                    schema
                };
            }

            Formio.builder(
                document.getElementById('formio-builder'),
                JSON.parse(definitionElement.value),
                {
                    noDefaultSubmitButton: false,
                    builder: {
                        premium: false,
                        resource: false,
                        registry: {
                            title: '@L["nav.registry_fields"]',
                            weight: -10,
                            default: true,
                            components: registryComponents
                        },
                        basic: { components: { password: false } }
                    }
                }
            ).then(builder => {
                document.getElementById('publish-form').disabled = false;
                formElement.addEventListener('submit', () => {
                    const definition = builder.form;
                    definition.title = document.getElementById('TitleEn').value.trim();
                    definition.properties ??= {};
                    definition.properties.titles = {
                        en: definition.title,
                        cs: document.getElementById('TitleCs').value.trim()
                    };
                    definitionElement.value = JSON.stringify(definition);
                });
            });
        })();
    </script>
}
