@page
@model CitizenService.Web.Pages.Admin.RegistryFieldsModel
@{
    ViewData["Title"] = L["admin.registry_fields.title"].Value;
}

<header class="mklu-admin-page-header">
    <p class="mklu-eyebrow">@L["nav.admin"]</p>
    <h1 class="mklu-heading-1">@L["admin.registry_fields.title"]</h1>
    <p class="mklu-text-secondary">@L["admin.registry_fields.description"]</p>
</header>

<div class="mklu-admin-workspace">
    <partial name="_AdminSidebar" model='new CitizenService.Web.Models.AdminSidebarViewModel { ActiveSection = "fields", Fields = Model.Definitions }' />

    <div class="mklu-admin-content">
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="mklu-alert @(Model.IsError ? "mklu-alert-error" : "mklu-alert-success")" role="status">
                @Model.Message
            </div>
        }

        <section class="mklu-admin-section">
            <div class="mklu-section-heading">
                <div>
                    <h2 class="mklu-heading-2">@(Model.EditingId is null ? L["admin.registry_fields.add"] : L["admin.registry_fields.edit"])</h2>
                    <p class="mklu-text-secondary">@(Model.EditingId is null ? L["admin.registry_fields.add_help"] : L["admin.registry_fields.edit_help"])</p>
                </div>
                <span class="mklu-count-summary">@Model.Definitions.Count @L["admin.registry_fields.total"]</span>
            </div>

            <form method="post" class="mklu-admin-form" data-registry-field-form>
                <input asp-for="EditingId" type="hidden" />
                <input asp-for="IsActive" type="hidden" />
                <fieldset class="mklu-form-section">
                    <legend>@L["admin.registry_fields.identity"]</legend>
                    <div class="mklu-form-grid">
                        <div class="mklu-field">
                            <label asp-for="Key">@L["admin.registry_fields.key"]</label>
                            <input asp-for="Key" pattern="[a-z][a-z0-9_]*" placeholder="date_of_birth" required />
                            <p class="mklu-field-help">@L["admin.registry_fields.key_help"]</p>
                        </div>
                        <div class="mklu-field">
                            <label asp-for="SortOrder">@L["admin.registry_fields.sort_order"]</label>
                            <input asp-for="SortOrder" type="number" min="0" />
                        </div>
                        <div class="mklu-field">
                            <label asp-for="LabelEn">@L["admin.registry_fields.label_en"]</label>
                            <input asp-for="LabelEn" required />
                        </div>
                        <div class="mklu-field">
                            <label asp-for="LabelCs">@L["admin.registry_fields.label_cs"]</label>
                            <input asp-for="LabelCs" />
                        </div>
                    </div>
                </fieldset>

                <fieldset class="mklu-form-section">
                    <legend>@L["admin.registry_fields.behavior"]</legend>
                    <div class="mklu-form-grid">
                        <div class="mklu-field">
                            <label asp-for="FieldType">@L["admin.registry_fields.type"]</label>
                            <select asp-for="FieldType" data-field-type>
                                <option value="Text">@L["admin.registry_fields.type_text"]</option>
                                <option value="MultilineText">@L["admin.registry_fields.type_multiline"]</option>
                                <option value="Date">@L["admin.registry_fields.type_date"]</option>
                                <option value="Integer">@L["admin.registry_fields.type_integer"]</option>
                                <option value="Decimal">@L["admin.registry_fields.type_decimal"]</option>
                                <option value="Boolean">@L["admin.registry_fields.type_boolean"]</option>
                                <option value="Select">@L["admin.registry_fields.type_select"]</option>
                            </select>
                        </div>
                    </div>
                    <div class="mklu-policy-options">
                        <label class="mklu-checkbox-option">
                            <input asp-for="IsRequired" type="checkbox" />
                            <span><strong>@L["admin.registry_fields.required"]</strong></span>
                        </label>
                        <label class="mklu-checkbox-option">
                            <input asp-for="UserEditable" type="checkbox" />
                            <span>
                                <strong>@L["admin.registry_fields.user_editable"]</strong>
                                <small>@L["admin.registry_fields.user_editable_help"]</small>
                            </span>
                        </label>
                    </div>
                </fieldset>

                <fieldset class="mklu-form-section" data-option-section hidden>
                    <legend>@L["admin.registry_fields.options"]</legend>
                    <div class="mklu-field">
                        <label asp-for="OptionSourceType">@L["admin.registry_fields.option_source"]</label>
                        <select asp-for="OptionSourceType" data-option-source>
                            <option value="None">@L["admin.registry_fields.option_none"]</option>
                            <option value="Static">@L["admin.registry_fields.option_static"]</option>
                            <option value="RemoteService">@L["admin.registry_fields.option_remote"]</option>
                        </select>
                    </div>
                    <div data-static-options hidden>
                        <div class="mklu-field">
                            <label asp-for="StaticOptions">@L["admin.registry_fields.static_options"]</label>
                            <textarea asp-for="StaticOptions" placeholder="cz | Czechia | Česko"></textarea>
                            <p class="mklu-field-help">@L["admin.registry_fields.static_options_help"]</p>
                        </div>
                    </div>
                    <div class="mklu-form-grid" data-remote-options hidden>
                        <div class="mklu-field">
                            <label asp-for="OptionSourceService">@L["admin.registry_fields.remote_service"]</label>
                            <input asp-for="OptionSourceService" />
                        </div>
                        <div class="mklu-field">
                            <label asp-for="OptionSourcePath">@L["admin.registry_fields.remote_path"]</label>
                            <input asp-for="OptionSourcePath" placeholder="/locations" />
                        </div>
                    </div>
                </fieldset>

                <div class="mklu-form-actions">
                    <button type="submit" class="mklu-btn mklu-btn-filled">@(Model.EditingId is null ? L["admin.registry_fields.create"] : L["admin.registry_fields.save"])</button>
                    @if (Model.EditingId is not null)
                    {
                        <a asp-page="/Admin/RegistryFields" class="mklu-btn mklu-btn-outlined">@L["admin.registry_fields.cancel"]</a>
                    }
                    <span class="mklu-text-secondary">@(Model.EditingId is null ? L["admin.registry_fields.create_help"] : L["admin.registry_fields.save_help"])</span>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.querySelector('[data-registry-field-form]');
            if (!form) return;

            const fieldType = form.querySelector('[data-field-type]');
            const optionSection = form.querySelector('[data-option-section]');
            const optionSource = form.querySelector('[data-option-source]');
            const staticOptions = form.querySelector('[data-static-options]');
            const remoteOptions = form.querySelector('[data-remote-options]');

            const updateOptions = () => {
                const isSelect = fieldType.value === 'Select';
                optionSection.hidden = !isSelect;
                if (!isSelect) optionSource.value = 'None';
                staticOptions.hidden = !isSelect || optionSource.value !== 'Static';
                remoteOptions.hidden = !isSelect || optionSource.value !== 'RemoteService';
            };

            fieldType.addEventListener('change', updateOptions);
            optionSource.addEventListener('change', updateOptions);
            updateOptions();
        })();
    </script>
}
