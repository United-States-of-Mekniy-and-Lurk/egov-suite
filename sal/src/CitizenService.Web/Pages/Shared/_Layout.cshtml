<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["app.name"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@300;400;600&family=Noto+Sans:wght@400;600&display=swap" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CitizenService.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{ var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName; }
    <a class="mklu-skip-link" href="#main-content">@L["app.skip_to_content"]</a>
    <header class="mklu-header" role="banner">
        <div class="mklu-header-inner">
            <div class="mklu-header-brand">
                <img src="~/img/MKLU-Flag-Small.svg" alt="" height="24" aria-hidden="true" />
                <div>
                    <a class="mklu-header-title" asp-page="/Index">@L["app.name"]</a>
                    <span class="mklu-header-subtitle">@L["app.country"]</span>
                </div>
            </div>
            <button type="button" class="mklu-menu-button" aria-expanded="false" aria-controls="main-navigation">
                <i data-lucide="menu" aria-hidden="true"></i>
                <span>@L["nav.menu"]</span>
            </button>
            <nav id="main-navigation" class="mklu-header-nav" aria-label="@L["nav.main"]">
                <a class="mklu-nav-link" asp-page="/Index"><i data-lucide="house" aria-hidden="true"></i><span>@L["nav.home"]</span></a>
                <a class="mklu-nav-link" asp-page="/Applications/Index"><i data-lucide="file-text" aria-hidden="true"></i><span>@L["nav.my_applications"]</span></a>
                @if (User.IsInRole("citizen-service:clerk") || User.IsInRole("citizen-service:admin"))
                {
                    <details class="mklu-nav-menu">
                        <summary class="mklu-nav-link">
                            <i data-lucide="briefcase-business" aria-hidden="true"></i>
                            <span>@L["nav.staff_tools"]</span>
                            <i class="mklu-nav-chevron" data-lucide="chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="mklu-nav-menu-panel">
                            <a asp-page="/Applications/Queue"><i data-lucide="clipboard-check" aria-hidden="true"></i>@L["nav.review_applications"]</a>
                            <a asp-page="/Corrections/Queue"><i data-lucide="list-checks" aria-hidden="true"></i>@L["nav.review_corrections"]</a>
                            <a asp-page="/Citizens/Index"><i data-lucide="users" aria-hidden="true"></i>@L["nav.citizens"]</a>
                            @if (User.IsInRole("citizen-service:admin"))
                            {
                                <span class="mklu-nav-menu-label">@L["nav.admin"]</span>
                                <a asp-page="/Admin/Forms"><i data-lucide="file-cog" aria-hidden="true"></i>@L["nav.forms"]</a>
                                <a asp-page="/Admin/RegistryFields"><i data-lucide="table-properties" aria-hidden="true"></i>@L["nav.registry_fields"]</a>
                            }
                        </div>
                    </details>
                }
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-page="/Language" class="mklu-language-switcher">
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <label class="mklu-visually-hidden" for="culture">@L["nav.language"]</label>
                        <i data-lucide="languages" aria-hidden="true"></i>
                        <select id="culture" name="culture" onchange="this.form.submit()">
                            @if (currentCulture == "cs")
                            {
                                <option value="en">English</option>
                                <option value="cs" selected>Čeština</option>
                            }
                            else
                            {
                                <option value="en" selected>English</option>
                                <option value="cs">Čeština</option>
                            }
                        </select>
                    </form>
                    <form method="post" asp-page="/Logout" class="mklu-nav-form">
                        <button type="submit" class="mklu-nav-link mklu-nav-button"><i data-lucide="log-out" aria-hidden="true"></i><span>@L["nav.logout"]</span></button>
                    </form>
                }
            </nav>
        </div>
    </header>
    <div class="mklu-page">
        <main id="main-content" role="main" class="mklu-main">
            @RenderBody()
        </main>
    </div>

    <footer class="mklu-footer" role="contentinfo">
        <div class="mklu-footer-inner">
            @L["footer.copyright", DateTime.Now.Year] &mdash; <a href="/Privacy">@L["nav.privacy"]</a>
        </div>
    </footer>

    <script src="~/lib/lucide/lucide.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
