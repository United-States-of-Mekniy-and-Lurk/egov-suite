<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Citizen Service</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@300;400;600&family=Noto+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CitizenService.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="mklu-skip-link" href="#main-content">Skip to main content</a>
    <header class="mklu-header" role="banner">
        <div class="mklu-header-inner">
            <div class="mklu-header-brand">
                <img src="~/img/MKLU-Flag-Small.svg" alt="" height="24" aria-hidden="true" />
                <div>
                    <a class="mklu-header-title" asp-page="/Index">Citizen Service</a>
                    <span class="mklu-header-subtitle">United States of Mekniy and Lurk</span>
                </div>
            </div>
            <nav class="mklu-header-nav" aria-label="Main navigation">
                <a class="mklu-nav-link" asp-page="/Index">Home</a>
                <a class="mklu-nav-link" asp-page="/Applications/Index">My applications</a>
            </nav>
        </div>
    </header>
    <div class="mklu-page">
        <main id="main-content" role="main" class="mklu-main">
            @RenderBody()
        </main>
    </div>

    <footer class="mklu-footer" role="contentinfo">
        <div class="mklu-footer-inner">
            &copy; 2026 United States of Mekniy and Lurk &mdash; <a href="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
