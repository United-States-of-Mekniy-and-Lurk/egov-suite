@page
@model CitizenService.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Citizen Service Dashboard</h1>
<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Total Citizens</h5>
                <p class="card-text display-4">@Model.TotalCitizens</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Pending Applications</h5>
                <p class="card-text display-4">@Model.PendingApplications</p>
            </div>
        </div>
    </div>
</div>

