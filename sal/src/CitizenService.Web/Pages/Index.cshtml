@page
@model CitizenService.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Citizen Service";
}

@if (Model.UserState == "error")
{
    <div class="mklu-alert mklu-alert-error" role="alert">
        <h2>Service unavailable</h2>
        <p>@Model.ErrorMessage</p>
        <p>Please try again later or contact support.</p>
    </div>
}
else
{
    <section class="mklu-section">
        <h1 class="mklu-heading-1">Your identity</h1>
        <div class="mklu-card" style="max-width: 560px;">
            <div class="mklu-card-body">
                <dl class="mklu-dl">
                    <dt>Name</dt>
                    <dd>@Model.Person?.DisplayName</dd>
                    <dt>Email</dt>
                    <dd>@Model.Person?.Email</dd>
                    <dt>Username</dt>
                    <dd>@Model.Person?.PreferredUsername</dd>
                </dl>
            </div>
        </div>
    </section>

    <section class="mklu-section">
        <h2 class="mklu-heading-2">Citizenship status</h2>

        @if (Model.UserState == "citizen")
        {
            <div class="mklu-card" style="max-width: 560px;">
                <div class="mklu-card-body">
                    <dl class="mklu-dl">
                        <dt>Status</dt>
                        <dd><span class="mklu-badge mklu-badge-@(Model.Citizen?.Status?.ToLowerInvariant())">@Model.Citizen?.Status</span></dd>
                        <dt>Citizen number</dt>
                        <dd>@Model.Citizen?.CitizenNumber</dd>
                        <dt>Granted</dt>
                        <dd>@Model.Citizen?.GrantedAt?.ToString("d MMMM yyyy")</dd>
                    </dl>
                </div>
            </div>
        }
        else if (Model.UserState == "pending")
        {
            <div class="mklu-card" style="max-width: 560px;">
                <div class="mklu-card-body">
                    <p class="mklu-body-lg">You have a citizenship application in progress.</p>
                    <dl class="mklu-dl">
                        <dt>Status</dt>
                        <dd><span class="mklu-badge mklu-badge-pending">@Model.PendingApplication?.Status</span></dd>
                        <dt>Submitted</dt>
                        <dd>@(Model.PendingApplication?.SubmittedAt?.ToString("d MMMM yyyy") ?? "Not yet submitted")</dd>
                    </dl>
                </div>
            </div>
        }
        else if (Model.UserState == "new")
        {
            <div class="mklu-card" style="max-width: 560px;">
                <div class="mklu-card-body">
                    <p class="mklu-body-lg">You are not yet a citizen of the United States of Mekniy and Lurk.</p>
                    <p class="mklu-text-secondary" style="margin-bottom: 24px;">
                        Submit a citizenship application to begin the process.
                    </p>
                    <form method="post" asp-page-handler="Apply">
                        <button type="submit" class="mklu-btn mklu-btn-filled">Apply for citizenship</button>
                    </form>
                </div>
            </div>
        }
    </section>
}

