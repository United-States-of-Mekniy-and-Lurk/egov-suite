@page
@model CitizenService.Web.Pages.IndexModel
@{
    ViewData["Title"] = L["app.name"].Value;
}

@if (Model.UserState == "error")
{
    <div class="mklu-alert mklu-alert-error" role="alert">
        <h2>@L["error.service_unavailable"]</h2>
        <p>@Model.ErrorMessage</p>
        <p>@L["error.try_again"]</p>
    </div>
}
else
{
    <section class="mklu-section">
        <h1 class="mklu-heading-1">@L["index.your_identity"]</h1>
        <div class="mklu-card" style="max-width: 560px;">
            <div class="mklu-card-body">
                <dl class="mklu-dl">
                    <dt>@L["common.name"]</dt>
                    <dd>@Model.Person?.DisplayName</dd>
                    <dt>@L["common.email"]</dt>
                    <dd>@Model.Person?.Email</dd>
                    <dt>@L["common.username"]</dt>
                    <dd>@Model.Person?.PreferredUsername</dd>
                </dl>
            </div>
        </div>
    </section>

    <section class="mklu-section">
        <h2 class="mklu-heading-2">@L["index.citizenship_status"]</h2>

        @if (Model.UserState == "citizen")
        {
            <div class="mklu-card" style="max-width: 560px;">
                <div class="mklu-card-body">
                    <dl class="mklu-dl">
                        <dt>@L["common.status"]</dt>
                        <dd><span class="mklu-badge mklu-badge-@(Model.Citizen?.Status?.ToLowerInvariant())">@L.StatusLabel(Model.Citizen?.Status)</span></dd>
                        <dt>@L["index.citizen_number"]</dt>
                        <dd>@Model.Citizen?.CitizenNumber</dd>
                        <dt>@L["index.granted"]</dt>
                        <dd>@Model.Citizen?.GrantedAt?.ToString("d MMMM yyyy")</dd>
                    </dl>
                </div>
            </div>
        }
        else if (Model.UserState == "pending")
        {
            <div class="mklu-card" style="max-width: 560px;">
                <div class="mklu-card-body">
                    <p class="mklu-body-lg">@L["index.pending_application"]</p>
                    <dl class="mklu-dl">
                        <dt>@L["common.status"]</dt>
                        <dd><span class="mklu-badge mklu-badge-pending">@L.StatusLabel(Model.PendingApplication?.Status)</span></dd>
                        <dt>@L["common.submitted"]</dt>
                        <dd>@(Model.PendingApplication?.SubmittedAt?.ToString("d MMMM yyyy") ?? L["index.not_yet_submitted"].Value)</dd>
                    </dl>
                    @if (Model.PendingApplication?.Status == "Draft")
                    {
                        <a asp-page="/Applications/New" asp-route-applicationId="@Model.PendingApplication?.Id" class="mklu-btn mklu-btn-filled">
                            <i data-lucide="file-pen-line" aria-hidden="true"></i>@L["index.continue_application"]
                        </a>
                    }
                </div>
            </div>
        }
        else if (Model.UserState == "new")
        {
            <div class="mklu-card" style="max-width: 560px;">
                <div class="mklu-card-body">
                    <p class="mklu-body-lg">@L["index.not_citizen"]</p>
                    <p class="mklu-text-secondary" style="margin-bottom: 24px;">
                        @L["index.not_citizen_cta"]
                    </p>
                    <form method="post" asp-page-handler="Apply">
                        <button type="submit" class="mklu-btn mklu-btn-filled"><i data-lucide="file-plus-2" aria-hidden="true"></i>@L["index.apply_button"]</button>
                    </form>
                </div>
            </div>
        }
    </section>

    @if (Model.UserState == "citizen")
    {
        var culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        <section class="mklu-section">
            <h2 class="mklu-heading-2">@L["index.registry_data"]</h2>
            <p class="mklu-text-secondary">@L["index.registry_data_description"]</p>
            <a asp-page="/Corrections/Index" class="mklu-inline-action">
                <i data-lucide="history" aria-hidden="true"></i>@L["corrections.view_requests"]
            </a>
            <div class="mklu-card" style="max-width: 720px;">
                <div class="mklu-card-body">
                    @if (Model.RegistryFields.Count == 0)
                    {
                        <p class="mklu-text-secondary">@L["index.registry_data_empty"]</p>
                    }
                    else
                    {
                        <dl class="mklu-dl mklu-registry-fields">
                            @foreach (var field in Model.RegistryFields)
                            {
                                <dt>@field.Definition.GetLabel(culture)</dt>
                                <dd>
                                    <span>@(string.IsNullOrEmpty(field.Value) ? L["common.not_yet"].Value : field.Value)</span>
                                    <span class="mklu-field-policy">
                                        @(field.Definition.UserEditable ? L["index.change_request_allowed"] : L["index.registry_managed"])
                                    </span>
                                    @if (field.Definition.UserEditable)
                                    {
                                        <a asp-page="/Corrections/New"
                                           asp-route-fieldKey="@field.Definition.Key"
                                           class="mklu-field-action">
                                            @L["index.request_correction"]
                                        </a>
                                    }
                                </dd>
                            }
                        </dl>
                    }
                </div>
            </div>
        </section>
    }
}

