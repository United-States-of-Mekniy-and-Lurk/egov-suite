@page
@model CitizenService.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Citizen Service";
}

@if (Model.UserState == "error")
{
    <div class="mklu-alert mklu-alert-error" role="alert">
        <h2>Service unavailable</h2>
        <p>@Model.ErrorMessage</p>
        <p>Please try again later or contact support.</p>
    </div>
}
else if (Model.UserState == "citizen")
{
    <section class="mklu-section">
        <h1 class="mklu-heading-1">Welcome back, @Model.Person?.DisplayName</h1>
        <p class="mklu-body-lg mklu-text-secondary">You are a registered citizen of Mekniy and Lurk.</p>

        <div class="mklu-card" style="max-width: 480px; margin-top: 32px;">
            <div class="mklu-card-body">
                <p class="mklu-label">Citizen number</p>
                <p class="mklu-body-lg" style="margin-bottom: 16px;">@Model.Citizen?.CitizenNumber</p>

                <p class="mklu-label">Status</p>
                <p class="mklu-body-lg" style="margin-bottom: 16px;">
                    <span class="mklu-badge mklu-badge-@(Model.Citizen?.Status?.ToLowerInvariant())">@Model.Citizen?.Status</span>
                </p>

                <p class="mklu-label">Granted</p>
                <p class="mklu-body-lg">@Model.Citizen?.GrantedAt?.ToString("d MMMM yyyy")</p>
            </div>
        </div>
    </section>
}
else if (Model.UserState == "new")
{
    <section class="mklu-section">
        <h1 class="mklu-heading-1">Apply for citizenship</h1>
        <p class="mklu-body-lg mklu-text-secondary" style="max-width: 640px;">
            Welcome, @Model.Person?.DisplayName. You are not yet a citizen of the United States of Mekniy and Lurk.
            Submit a citizenship application to begin the process.
        </p>

        <div class="mklu-card" style="max-width: 560px; margin-top: 32px;">
            <div class="mklu-card-body">
                <h2 class="mklu-heading-3">Your identity</h2>
                <dl class="mklu-dl">
                    <dt>Name</dt>
                    <dd>@Model.Person?.DisplayName</dd>
                    <dt>Email</dt>
                    <dd>@Model.Person?.Email</dd>
                    <dt>Person ID</dt>
                    <dd><code>@Model.Person?.Id</code></dd>
                </dl>

                <form method="post" action="/Applications/New" style="margin-top: 24px;">
                    <input type="hidden" name="personId" value="@Model.Person?.Id" />
                    <input type="hidden" name="formName" value="citizenship_application" />
                    <input type="hidden" name="formVersion" value="1" />
                    <button type="submit" class="mklu-btn mklu-btn-filled">Submit application</button>
                </form>
            </div>
        </div>
    </section>
}

