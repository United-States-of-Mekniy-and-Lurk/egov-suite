@page
@model CitizenService.Web.Pages.Applications.ApplicationDetailModel
@{
    ViewData["Title"] = "Application Detail";
}

<h1 class="mklu-heading-1">Application Detail</h1>
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="mklu-alert mklu-alert-error" role="alert">
        <strong>@L["applications.transition_failed"]</strong>
        <span>@Model.ErrorMessage</span>
    </div>
}
@if (Model.Application != null)
{
    <dl class="mklu-dl">
        <dt>ID</dt>
        <dd>@Model.Application.Id</dd>
        <dt>Person ID</dt>
        <dd>@Model.Application.PersonId</dd>
        <dt>Status</dt>
        <dd>@Model.Application.Status</dd>
        <dt>Form</dt>
        <dd>@Model.Application.FormName v@Model.Application.FormVersion</dd>
        <dt>Submitted At</dt>
        <dd>@Model.Application.SubmittedAt</dd>
        <dt>Decision Reason</dt>
        <dd>@Model.Application.DecisionReason</dd>
    </dl>

    <form method="post" class="mklu-form">
        <input type="hidden" name="id" value="@Model.Application.Id" />
        <div class="mklu-field">
            <label>Transition To</label>
            <select name="targetState">
                <option value="UnderReview">Under Review</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
            </select>
        </div>
        <div class="mklu-field">
            <label>Reason</label>
            <textarea name="reason"></textarea>
        </div>
        <button type="submit" class="mklu-btn mklu-btn-filled">Apply Transition</button>
    </form>
}
<a href="/Applications" class="mklu-btn mklu-btn-outlined">Back</a>
