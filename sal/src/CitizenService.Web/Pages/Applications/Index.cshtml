@page
@model CitizenService.Web.Pages.Applications.ApplicationsIndexModel
@{
    ViewData["Title"] = L["applications.title"].Value;
}

<h1 class="mklu-heading-1">@L["applications.title"]</h1>

@if (Model.Applications.Count == 0)
{
    <p class="mklu-text-secondary">@L["applications.empty"]</p>
}
else
{
    @foreach (var a in Model.Applications)
    {
        <div class="mklu-card" style="max-width: 560px; margin-bottom: 16px;">
            <div class="mklu-card-body">
                <dl class="mklu-dl">
                    <dt>@L["common.status"]</dt>
                    <dd><span class="mklu-badge mklu-badge-@(a.Status.ToLowerInvariant())">@a.Status</span></dd>
                    <dt>@L["common.created"]</dt>
                    <dd>@a.CreatedAt.ToString("d MMMM yyyy")</dd>
                    <dt>@L["common.submitted"]</dt>
                    <dd>@(a.SubmittedAt?.ToString("d MMMM yyyy") ?? L["common.not_yet"].Value)</dd>
                    @if (a.ReviewedAt.HasValue)
                    {
                        <dt>@L["common.reviewed"]</dt>
                        <dd>@a.ReviewedAt.Value.ToString("d MMMM yyyy")</dd>
                    }
                    @if (!string.IsNullOrEmpty(a.DecisionReason))
                    {
                        <dt>@L["common.decision"]</dt>
                        <dd>@a.DecisionReason</dd>
                    }
                </dl>
                @if (a.Status == "Draft")
                {
                    <a asp-page="/Applications/New"
                       asp-route-applicationId="@a.Id"
                       class="mklu-btn mklu-btn-filled">
                        @L["index.continue_application"]
                    </a>
                }
            </div>
        </div>
    }
}
