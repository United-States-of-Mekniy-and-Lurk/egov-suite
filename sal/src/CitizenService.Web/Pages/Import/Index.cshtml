@page
@model CitizenService.Web.Pages.Import.ImportIndexModel
@{
    ViewData["Title"] = L["import.title"].Value;
}

<h1 class="mklu-heading-1">@L["import.title"]</h1>
<p>@L["import.expected_columns"]</p>

@if (Model.ImportResult != null)
{
    <div class="mklu-alert mklu-alert-info" role="status">
        @L["import.result", Model.ImportResult.Imported, Model.ImportResult.Errors.Count]
        @if (Model.ImportResult.Errors.Any())
        {
            <ul>
                @foreach (var error in Model.ImportResult.Errors)
                {
                    <li>@error</li>
                }
            </ul>
        }
    </div>
}

<form method="post" enctype="multipart/form-data" class="mklu-form">
    <div class="mklu-field">
        <label>@L["import.file"]</label>
        <input type="file" name="file" accept=".csv" required />
    </div>
    <button type="submit" class="mklu-btn mklu-btn-filled"><i data-lucide="upload" aria-hidden="true"></i>@L["import.upload"]</button>
</form>
