@page
@model CitizenService.Web.Pages.Import.ImportIndexModel
@{
    ViewData["Title"] = "CSV Import";
}

<h1 class="mklu-heading-1">Import Citizens from CSV</h1>
<p>Expected columns: PersonId, CitizenNumber, GrantedAt, ImportSource</p>

@if (Model.ImportResult != null)
{
    <div class="mklu-alert mklu-alert-info" role="status">
        Imported: @Model.ImportResult.Imported rows. Errors: @Model.ImportResult.Errors.Count
        @if (Model.ImportResult.Errors.Any())
        {
            <ul>
                @foreach (var error in Model.ImportResult.Errors)
                {
                    <li>@error</li>
                }
            </ul>
        }
    </div>
}

<form method="post" enctype="multipart/form-data" class="mklu-form">
    <div class="mklu-field">
        <label>CSV File</label>
        <input type="file" name="file" accept=".csv" required />
    </div>
    <button type="submit" class="mklu-btn mklu-btn-filled">Upload</button>
</form>
