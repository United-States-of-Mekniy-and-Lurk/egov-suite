@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
}
<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["portal.app.name"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">@L["portal.skip_to_content"]</a>
    <header class="site-header">
        <div class="header-inner">
            <a class="brand" asp-page="/Index" aria-label="@L["portal.home_aria"]">
                <img src="~/img/MKLU-Flag-Small.svg" alt="" aria-hidden="true" />
                <span><strong>@L["portal.app.name"]</strong><small>@L["portal.app.country"]</small></span>
            </a>
            <nav aria-label="@L["portal.nav.aria"]">
                <a asp-page="/Index"><svg class="icon" aria-hidden="true"><use href="/img/icons.svg#services" /></svg>@L["portal.nav.services"]</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-page="/Overview"><svg class="icon" aria-hidden="true"><use href="/img/icons.svg#user" /></svg>@L["portal.nav.overview"]</a>
                    <form method="post" asp-page="/Logout">
                        <button type="submit"><svg class="icon" aria-hidden="true"><use href="/img/icons.svg#log-out" /></svg>@L["portal.nav.sign_out"]</button>
                    </form>
                }
                else
                {
                    <a class="sign-in" asp-page="/Login" asp-route-returnUrl="/Overview"><svg class="icon" aria-hidden="true"><use href="/img/icons.svg#log-in" /></svg>@L["portal.nav.sign_in"]</a>
                }
                <form method="post" asp-page="/Culture" class="language-picker">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <svg class="icon" aria-hidden="true"><use href="/img/icons.svg#languages" /></svg>
                    <label class="visually-hidden" for="portal-language">@L["portal.language.label"]</label>
                    <select id="portal-language" name="culture" onchange="this.form.submit()">
                        <option value="en" selected="@(culture == "en")">EN</option>
                        <option value="cs" selected="@(culture == "cs")">CS</option>
                    </select>
                </form>
            </nav>
        </div>
    </header>

    <main id="main-content">@RenderBody()</main>

    <footer>
        <div class="footer-inner">
            <span class="footer-government">
                <img src="~/img/manticore.svg" alt="" aria-hidden="true" />
                @L["portal.footer.government"]
            </span>
            <a asp-page="/Privacy">@L["portal.nav.privacy"]</a>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>