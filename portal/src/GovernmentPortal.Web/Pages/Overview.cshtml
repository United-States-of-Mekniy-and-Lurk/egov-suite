@page
@model OverviewModel
@{
    ViewData["Title"] = L["portal.nav.overview"].Value;
    var displayName = User.FindFirst("name")?.Value ?? User.Identity?.Name ?? "there";
}

<section class="content-width overview-header">
    <p class="eyebrow">@L["portal.index.personal_overview"]</p>
    <h1>@L["portal.overview.welcome", displayName]</h1>
    <p>@L["portal.overview.lead"]</p>
</section>

<section class="content-width module-grid" aria-label="@L["portal.overview.aria"]">
    @foreach (var module in Model.Modules)
    {
        <article class="module module-@module.Tone">
            <svg class="module-icon" aria-hidden="true"><use href="/img/icons.svg#file-check" /></svg>
            <span class="module-status">@L["portal.overview.available"]</span>
            <h2>@module.Title</h2>
            <p>@module.Summary</p>
            <a href="@module.ActionUrl">@module.ActionLabel <svg class="icon" aria-hidden="true"><use href="/img/icons.svg#arrow-right" /></svg></a>
        </article>
    }
    <article class="module module-neutral">
        <svg class="module-icon" aria-hidden="true"><use href="/img/icons.svg#building" /></svg>
        <span class="module-status">@L["portal.overview.coming_later"]</span>
        <h2>@L["portal.overview.companies"]</h2>
        <p>@L["portal.overview.companies_summary"]</p>
    </article>
</section>